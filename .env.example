# Copy to .env — docker compose reads it automatically:  cp .env.example .env

# Postgres password (also baked into DATABASE_URL for the server)
POSTGRES_PASSWORD=password

# Signs TON Proof payloads and session JWTs — use a long random string
TONPROOF_PAYLOAD_SIGNATURE_KEY=change_me

# Authorizes POST /api/close (event resolution + payouts) — use a long random string
ADMIN_SECRET_KEY=change_me

# Treasury address that receives bets
BANK_ADDR=EQBRW9rjhRUNL-Sy4swYbMzm2MgvlhC2DWIZFhYp2JnSoJaA

# 24-word mnemonic of the payout hot wallet.
# The value below is the PUBLIC example seed from the tongo docs — replace it before touching real funds.
WALLET_SEED=example consider fiscal mail guitar tiger duck exhibit ancient series differ wealth mix kitchen cactus upgrade unable yellow impact confirm denial mesh during dove
